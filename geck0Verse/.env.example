GECK0_ENV=production
GECK0_TIMEZONE=Europe/London
GECK0_API_TOKEN=CHANGE_ME_GENERATED_BY_INSTALLER
GECK0_INTERNAL_TOKEN=CHANGE_ME_GENERATED_BY_INSTALLER
GECK0_FERNET_KEY=CHANGE_ME_GENERATED_BY_INSTALLER
GECK0_DATA_ROOT=/data
GECK0_UPLOAD_LIMIT_MB=25
GECK0_CORS_ORIGINS=*

# JE / network
JE_HOST=192.168.1.244
JE_SSH_PORT=1991
GECK0_PROJECTS_ROOT=/home/lucy/geck0Projects
PUBLIC_BASE_URL=http://192.168.1.244:8088

# Crumble LLM (optional)
CRUMBLE_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:4b
OPENAI_API_KEY=

# Travel connectors (optional)
TICKETMASTER_API_KEY=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
TRAVELSHEEP_JSON_FEED_URL=

# SeaLife connectors (optional)
SEALIFE_JSON_FEED_URL=
SEALIFE_CSV_PATH=/data/sealife/import/listings.csv

# Green Geck0
GREEN_ALLOW_PRIVATE=false

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
DEFAULT_WEBHOOK_URL=

# PostgreSQL shared history
POSTGRES_DB=geck0verse
POSTGRES_USER=geck0
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_INSTALLER
DATABASE_URL=postgresql+psycopg://geck0:CHANGE_ME_GENERATED_BY_INSTALLER@postgres:5432/geck0verse
